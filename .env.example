# Comma-separated browser origins allowed to call this service.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Absolute or relative path to your trained inference model. Leave blank until ready.
# Pretrained model provider. The default calls the selected Hugging Face Space.
DETECTOR_PROVIDER=huggingface_space
HF_SPACE_ID=Sara1708/deepfake-audio-detector
# Optional: improves public-Space rate limits. Never expose this token in frontend code.
HF_TOKEN=
